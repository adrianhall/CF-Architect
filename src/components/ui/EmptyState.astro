---
/**
 * EmptyState component — a centred placeholder shown when a list has no items.
 * Optionally renders a call-to-action button.
 *
 * @example
 * <EmptyState
 *   title="No diagrams yet"
 *   description="Get started by creating your first diagram."
 *   actionLabel="Create your first diagram"
 *   actionHref="/canvas/new"
 * />
 */

import Button from './Button.astro'

interface Props {
  /** Primary heading shown in the empty state. */
  title: string
  /** Optional supporting text below the title. */
  description?: string
  /** Label for the optional CTA button. */
  actionLabel?: string
  /** Href for the optional CTA button. Renders as `<a>` when provided. */
  actionHref?: string
}

const { title, description, actionLabel, actionHref } = Astro.props
---

<div class="flex flex-col items-center justify-center px-4 py-20 text-center">
  <!-- Icon placeholder -->
  <div class="bg-cf-gray-100 mb-4 flex h-16 w-16 items-center justify-center rounded-full">
    <svg
      class="text-cf-gray-500 h-8 w-8"
      xmlns="http://www.w3.org/2000/svg"
      fill="none"
      viewBox="0 0 24 24"
      stroke="currentColor"
      aria-hidden="true"
    >
      <path
        stroke-linecap="round"
        stroke-linejoin="round"
        stroke-width="1.5"
        d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"
      ></path>
    </svg>
  </div>

  <h3 class="text-cf-gray-900 text-lg font-semibold">{title}</h3>

  {description && <p class="text-cf-gray-500 mt-1 max-w-sm text-sm">{description}</p>}

  {
    actionLabel && actionHref && (
      <div class="mt-6">
        <Button href={actionHref}>{actionLabel}</Button>
      </div>
    )
  }
</div>
