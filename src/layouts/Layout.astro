---
/**
 * Base HTML layout for all pages.
 *
 * Provides the document shell with proper meta tags, Tailwind CSS, a content
 * slot, and a globally-mounted sonner `<Toaster>` for toast notifications.
 *
 * The Toaster is imported directly from the `sonner` npm package rather than
 * the shadcn-generated wrapper (which requires `next-themes`).
 * Ref: https://sonner.emilkowal.ski/
 */

import { Toaster } from 'sonner'
import '../styles/global.css'

interface Props {
  /** The page title displayed in the browser tab. */
  title: string
}

const { title } = Astro.props
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
  </head>
  <body>
    <slot />
    <!-- Global toast container — hydrated immediately so toasts work on any page -->
    <Toaster client:load position="bottom-right" richColors />
  </body>
</html>
