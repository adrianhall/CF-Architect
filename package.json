{
  "name": "cf-architect",
  "type": "module",
  "version": "6.0.0",
  "license": "MIT",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "predev": "run-s db:migrate:local",
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "predeploy": "run-s build",
    "deploy": "wrangler deploy",
    "firstrun": "cd terraform && terraform init && terraform apply",
    "check": "run-p check:*",
    "check:types": "tsc --noEmit",
    "check:eslint": "eslint .",
    "check:prettier": "prettier --check .",
    "fullcheck": "run-s check test:coverage",
    "pretest": "run-s build",
    "test": "vitest run",
    "pretest:watch": "run-s build",
    "test:watch": "vitest",
    "pretest:coverage": "run-s build",
    "test:coverage": "vitest run --coverage",
    "pretest:e2e": "run-s build db:migrate:local",
    "test:e2e": "playwright test",
    "generate-types": "wrangler types",
    "db:migrate": "wrangler d1 migrations apply cf-architect-db",
    "db:migrate:local": "wrangler d1 migrations apply cf-architect-db --local",
    "clean": "rimraf dist .astro .wrangler coverage test-results"
  },
  "dependencies": {
    "@astrojs/cloudflare": "^13.1.9",
    "@astrojs/react": "^5.0.3",
    "@tailwindcss/vite": "^4.2.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "astro": "^6.1.6",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "kysely": "^0.28.16",
    "kysely-d1": "^0.4.0",
    "lucide-react": "^1.8.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.2",
    "tldraw": "^4.5.8",
    "wrangler": "^4.82.2"
  },
  "overrides": {
    "vite": "^7"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.14.6",
    "@playwright/test": "^1.59.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.6.0",
    "@typescript-eslint/eslint-plugin": "^8.58.2",
    "@typescript-eslint/parser": "^8.58.2",
    "@vitest/coverage-istanbul": "^4.1.4",
    "eslint": "^9.39.4",
    "eslint-plugin-astro": "^1.7.0",
    "npm-run-all2": "^8.0.4",
    "prettier": "^3.8.2",
    "prettier-plugin-astro": "^0.14.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "rimraf": "^6.1.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.58.2",
    "vitest": "^4.1.4"
  }
}
