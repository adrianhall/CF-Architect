# CF-Architect environment configuration
# Copy this file to .env and fill in the values.
#
# Quick start: run `npm run firstrun` to provision all Cloudflare resources
# automatically via Terraform (see docs/TERRAFORM.md).
#
# Manual setup: see docs/DEPLOY.md.

# ---------------------------------------------------------------------------
# Cloudflare resource IDs
# Auto-populated by `npm run firstrun`, or fill in manually after provisioning.
# ---------------------------------------------------------------------------
D1_DATABASE_ID=
KV_NAMESPACE_ID=
SESSION_NAMESPACE_ID=

# ---------------------------------------------------------------------------
# Cloudflare Access team domain (e.g. "photoadrian" for photoadrian.cloudflareaccess.com)
# Required in production for JWT verification.
# Auto-populated by `npm run firstrun`, or set manually / via `wrangler secret put`.
# ---------------------------------------------------------------------------
CF_ACCESS_TEAM_DOMAIN=

# ---------------------------------------------------------------------------
# Required for `npm run firstrun` (Terraform-based setup)
# ---------------------------------------------------------------------------

# Cloudflare API token — needs: D1 Edit, Workers KV Storage Edit,
# Access: Apps and Policies Edit, Access: Organizations/IdPs/Groups Edit
CLOUDFLARE_API_TOKEN=

# Cloudflare account ID (visible in the dashboard URL or Account Home)
CLOUDFLARE_ACCOUNT_ID=

# Your Cloudflare Workers subdomain (e.g. "photoadrian.workers.dev")
CF_WORKERS_DOMAIN=

# GitHub OAuth App credentials
# Create at: https://github.com/settings/developers → OAuth Apps → New OAuth App
# Callback URL: https://<CF_ACCESS_TEAM_DOMAIN>.cloudflareaccess.com/cdn-cgi/access/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
